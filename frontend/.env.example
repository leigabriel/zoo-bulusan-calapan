# DEVELOPMENT
VITE_BACKEND_PORT=5000
VITE_APP_MODE=development
VITE_MINIZOO_GAME_URL=http://localhost:5174

# AI Scanner Configuration
# -------------------------
# The AI Scanner routes requests through the backend proxy to avoid CORS issues.
# The API key is stored securely on the server, not in the frontend.
#
# AI Source Options:
#   - 'backend': Routes through server proxy → AnimalDetect API (recommended)
#   - 'local': Uses TensorFlow.js model directly in browser (no API needed)
#
# Set VITE_AI_SOURCE to control which detection method is used.
# If using 'backend', configure ANIMAL_DETECT_API_KEY in backend/.env
#
VITE_AI_SOURCE=backend

# Backend API URL (optional - auto-detected in development)
# VITE_API_URL=http://localhost:5000/api

# PRODUCTION
# VITE_API_URL=https://your-api.onrender.com/api
# VITE_BACKEND_URL=https://your-api.onrender.com
# VITE_APP_MODE=production
# VITE_MINIZOO_GAME_URL=https://your-minizoo-game.vercel.app