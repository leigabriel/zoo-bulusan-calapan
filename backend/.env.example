# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# Database (Local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bulusanzoocalapandatabase

# JWT
JWT_SECRET=your-secure-random-secret-key-min-32-chars
JWT_EXPIRE=7d

# URLs
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# AI
GEMINI_API_KEY=your-gemini-api-key

# ===========================================
# PRODUCTION CONFIGURATION (uncomment below)
# ===========================================
# PORT=10000
# NODE_ENV=production
# DB_HOST=your-db-host.provider.com
# DB_PORT=3306
# DB_USER=your_prod_user
# DB_PASSWORD=your_prod_password
# DB_NAME=your_prod_database
# DB_SSL_REJECT_UNAUTHORIZED=false
# CORS_ORIGIN=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# GOOGLE_CALLBACK_URL=https://your-api.onrender.com/auth/google/callback
