# DEVELOPMENT
PORT=5000
NODE_ENV=development

# Localhost Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bulusanzoocalapandatabase

# JWT
JWT_SECRET=your-secure-random-secret-key-min-32-chars
JWT_EXPIRE=7d

# URLs
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# AI
GEMINI_API_KEY=your-gemini-api-key

# AnimalDetect API (for AI Scanner)
# The API key is stored securely on the server to avoid CORS issues
# Get your API key from https://www.animaldetect.com
ANIMAL_DETECT_API_KEY=your-animaldetect-api-key
ANIMAL_DETECT_API_URL=https://www.animaldetect.com/api/v1/detect
ANIMAL_DETECT_TIMEOUT=30000
ANIMAL_DETECT_MIN_CONFIDENCE=0.10

# Cloudinary (Cloud Image Storage)
# Get your credentials from https://cloudinary.com/console
# If not configured, uploads will fall back to local storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# PRODUCTION
# PORT=10000
# NODE_ENV=production
# DB_HOST=your-db-host.provider.com
# DB_PORT=3306
# DB_USER=your_prod_user
# DB_PASSWORD=your_prod_password
# DB_NAME=your_prod_database
# DB_SSL_REJECT_UNAUTHORIZED=false
# CORS_ORIGIN=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# GOOGLE_CALLBACK_URL=https://your-api.onrender.com/auth/google/callback